{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "overleaf": {
      "type": "local",
      "command": ["<path-to-OverLeaf-MCP>/venv/Scripts/python.exe", "<path-to-OverLeaf-MCP>/server.py"],
      "timeout": 60000,
      "environment": {
        "OVERLEAF_GIT_URL": "https://git.overleaf.com/<your-project-id>",
        "OVERLEAF_TOKEN": "olp_<your-token>"
      }
    }
  }
}
